[core]
	pager = delta
	fsmonitor = true
	untrackedCache = true
[alias]
  # ── Cheatsheet ───────────────────────────────────────────────────────────────
	aliases = "!printf '\n\\033[1;36m  Git Aliases Cheatsheet\\033[0m\n\n\\033[33m── Aliases ─────────────────────────────────\\033[0m\n  \\033[1maliases\\033[0m       Show this cheatsheet\n\n\\033[33m── Status & Diff ───────────────────────────\\033[0m\n  \\033[1mst\\033[0m            status -sb             Short branch status\n  \\033[1mdf\\033[0m            diff                   Diff working tree\n  \\033[1mdfc\\033[0m           diff --cached           Diff staged changes\n  \\033[1mdfs\\033[0m           diff --stat             Diff with file stats\n\n\\033[33m── Staging ─────────────────────────────────\\033[0m\n  \\033[1ma\\033[0m             add                    Stage a file\n  \\033[1maa\\033[0m            add --all               Stage everything\n  \\033[1map\\033[0m            add --patch             Stage interactively hunk by hunk\n\n\\033[33m── Committing ──────────────────────────────\\033[0m\n  \\033[1mci\\033[0m            commit                 Open commit editor\n  \\033[1mcm\\033[0m            commit -m              Commit with inline message\n  \\033[1mca\\033[0m            commit --amend         Amend last commit\n  \\033[1mcan\\033[0m           commit --amend --no-edit   Amend, keep message\n  \\033[1mwip\\033[0m           commit -am WIP         Quick WIP commit\n  \\033[1mcmp\\033[0m           commit -m + push        Commit with message then push\n\n\\033[33m── Branching ───────────────────────────────\\033[0m\n  \\033[1mbr\\033[0m            branch                 List local branches\n  \\033[1mbra\\033[0m           branch -a               List all branches incl remote\n  \\033[1msw\\033[0m            switch                 Switch branch\n  \\033[1mswc\\033[0m           switch -c               Create and switch to new branch\n  \\033[1mco\\033[0m            checkout               Checkout\n  \\033[1mcob\\033[0m           checkout -b             Checkout and create new branch\n  \\033[1mcpbr\\033[0m          branch --show-current   Copy current branch name to clipboard\n  \\033[1mclean-merged\\033[0m  branch --merged main    Delete local branches merged to main\n\n\\033[33m── Logging ─────────────────────────────────\\033[0m\n  \\033[1mlg\\033[0m            log graph all          Full branch graph\n  \\033[1mll\\033[0m            log graph last 20      Recent 20 commits graph\n  \\033[1mlast\\033[0m          log -1 HEAD --stat      Last commit with changed files\n  \\033[1mwho\\033[0m           shortlog -sn            Contributor commit counts\n\n\\033[33m── Remote ──────────────────────────────────\\033[0m\n  \\033[1mpl\\033[0m            pull                   Pull\n  \\033[1mps\\033[0m            push                   Push\n  \\033[1mpsf\\033[0m           push --force-with-lease   Safe force push\n  \\033[1mpsu\\033[0m           push --set-upstream     Push and set upstream to HEAD\n  \\033[1mrv\\033[0m            remote -v               List remotes\n\n\\033[33m── Resetting ───────────────────────────────\\033[0m\n  \\033[1mrs\\033[0m            reset --soft to branch  Soft reset to origin/branch (default: master)\n  \\033[1mrh\\033[0m            reset --hard to branch  Hard reset to origin/branch (default: master)\n\n\\033[33m── Undoing ─────────────────────────────────\\033[0m\n  \\033[1munstage\\033[0m       reset HEAD --           Unstage a file\n  \\033[1mundo\\033[0m          reset HEAD~1 --mixed    Undo last commit, keep unstaged\n  \\033[1mundos\\033[0m         reset HEAD~1 --soft     Undo last commit, keep staged\n  \\033[1mdiscard\\033[0m       checkout --             Discard working tree changes\n\n\\033[33m── Stashing ────────────────────────────────\\033[0m\n  \\033[1mss\\033[0m            stash save              Save stash\n  \\033[1msp\\033[0m            stash pop               Pop stash\n  \\033[1msl\\033[0m            stash list              List stashes\n\n\\033[33m── Utility ─────────────────────────────────\\033[0m\n  \\033[1mroot\\033[0m          rev-parse --show-toplevel   Print repo root\n  \\033[1mignored\\033[0m       ls-files --ignored      Show gitignored files\n  \\033[1mcontributors\\033[0m  shortlog -sn             Contributor counts\n\n'"

  # ── Status & diff ────────────────────────────────────────────────────────────
  st        = status -sb
  df        = diff
  dfc       = diff --cached
  dfs       = diff --stat

  # ── Staging ──────────────────────────────────────────────────────────────────
  a         = add
  aa        = add --all
  ap        = add --patch

  # ── Committing ───────────────────────────────────────────────────────────────
  ci        = commit
  cm        = commit -m
  ca        = commit --amend
  can       = commit --amend --no-edit
  wip       = commit -am "WIP"

  # ── Branching ────────────────────────────────────────────────────────────────
  br        = branch
  bra       = branch -a
  sw        = switch
  swc       = switch -c
  co        = checkout
  cob       = checkout -b
  cpbr      = !git branch --show-current | pbcopy
  clean-merged = !git branch --merged main | grep -v "main" | xargs git branch -d

  # ── Logging ──────────────────────────────────────────────────────────────────
  lg        = log --oneline --graph --decorate --all
  ll        = log --oneline --graph --decorate -20
  last      = log -1 HEAD --stat
  who       = shortlog -sn --no-merges

  # ── Remote ───────────────────────────────────────────────────────────────────
	pl = pull origin
	ps = push origin
  psf       = push --force-with-lease
  psu       = push --set-upstream origin HEAD
  rv        = remote -v

  # ── Resetting ────────────────────────────────────────────────────────────────
  rs        = "!f() { git fetch origin && git reset --soft \"origin/${1:-master}\"; }; f"
  rh        = "!f() { git fetch origin && git reset --hard \"origin/${1:-master}\"; }; f"

  # ── Undoing ──────────────────────────────────────────────────────────────────
  unstage   = reset HEAD --
  undo      = reset HEAD~1 --mixed
  undos     = reset HEAD~1 --soft
  discard   = checkout --

  # ── Stashing ─────────────────────────────────────────────────────────────────
  ss        = stash save
  sp        = stash pop
  sl        = stash list

  # ── Commit + push ────────────────────────────────────────────────────────────
  cmp       = "!f() { git commit -m \"$1\" && git push; }; f"

  # ── Utility ──────────────────────────────────────────────────────────────────
  root      = rev-parse --show-toplevel
  ignored   = ls-files --others --ignored --exclude-standard
  contributors = shortlog -sn
[credential "https://github.com"]
	helper =
	helper = !gh auth git-credential
[credential "https://gist.github.com"]
	helper =
	helper = !gh auth git-credential
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
	side-by-side = true
	line-numbers = true
[merge]
	conflictstyle = zdiff3
[include]
	path = ~/.gitconfig.local
