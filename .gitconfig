[core]
	pager = delta
[alias]
	st = status
	cm = commit -m
	gl = config --global -l
	co = checkout
	cob = checkout -b
	del = branch -D
	pul = pull origin
	alias = ! git config --get-regexp ^alias\\. | sed -e s/^alias\\.// -e s/\\ /\\ =\\ /
	p = push -u origin
	l = log --oneline --graph --decorate
	undo = reset HEAD~1 --soft
[credential "https://github.com"]
	helper =
	helper = !gh auth git-credential
[credential "https://gist.github.com"]
	helper =
	helper = !gh auth git-credential
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
	side-by-side = true
	line-numbers = true
[merge]
	conflictstyle = zdiff3
[include]
	path = /Users/justindeocampo/.gitconfig.local
