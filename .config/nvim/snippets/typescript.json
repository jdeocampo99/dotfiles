{
  "export function": {
    "prefix": "efn",
    "body": ["export function ${1:name}(${2:params}: ${3:type}): ${4:ReturnType} {", "\t$0", "}"],
    "description": "Export function declaration"
  },
  "export async function": {
    "prefix": "eafn",
    "body": ["export async function ${1:name}(${2:params}: ${3:type}): Promise<${4:ReturnType}> {", "\t$0", "}"],
    "description": "Export async function declaration"
  },
  "function declaration": {
    "prefix": "fn",
    "body": ["function ${1:name}(${2:params}: ${3:type}): ${4:ReturnType} {", "\t$0", "}"],
    "description": "Function declaration"
  },
  "const arrow function": {
    "prefix": "af",
    "body": ["const ${1:name} = (${2:params}: ${3:type}): ${4:ReturnType} => {", "\t$0", "}"],
    "description": "Const arrow function"
  },
  "export const arrow function": {
    "prefix": "eaf",
    "body": ["export const ${1:name} = (${2:params}: ${3:type}): ${4:ReturnType} => {", "\t$0", "}"],
    "description": "Export const arrow function"
  },
  "arrow function (inline)": {
    "prefix": "afi",
    "body": ["(${1:params}: ${2:type}) => ${0:expression}"],
    "description": "Inline arrow function"
  },

  "interface": {
    "prefix": "int",
    "body": ["interface ${1:Name} {", "\t${2:property}: ${3:type}", "$0", "}"],
    "description": "Interface declaration"
  },
  "type alias": {
    "prefix": "type",
    "body": ["type ${1:Name} = ${2:type}"],
    "description": "Type alias"
  },
  "export interface": {
    "prefix": "eint",
    "body": ["export interface ${1:Name} {", "\t${2:property}: ${3:type}", "$0", "}"],
    "description": "Export interface declaration"
  },
  "export type alias": {
    "prefix": "etype",
    "body": ["export type ${1:Name} = ${2:type}"],
    "description": "Export type alias"
  },
  "Record type": {
    "prefix": "rec",
    "body": ["Record<${1:string}, ${2:type}>"],
    "description": "Record<K, V> utility type"
  },
  "Partial type": {
    "prefix": "part",
    "body": ["Partial<${1:Type}>"],
    "description": "Partial<T> utility type"
  },
  "Pick type": {
    "prefix": "pick",
    "body": ["Pick<${1:Type}, ${2:keys}>"],
    "description": "Pick<T, K> utility type"
  },
  "Omit type": {
    "prefix": "omit",
    "body": ["Omit<${1:Type}, ${2:keys}>"],
    "description": "Omit<T, K> utility type"
  },

  "React Query useQuery hook": {
    "prefix": "uq",
    "body": [
      "import { useQuery } from '@tanstack/react-query'",
      "import { ${1:useClient} } from '${2:../utils/ug}'",
      "import { ${3:queryKeys} } from './${4:queryKeys}'",
      "",
      "export const use${5:Name} = (${6:params}: ${7:ParamsType}) => {",
      "\tconst client = ${1:useClient}()",
      "",
      "\treturn useQuery<${8:ResponseType}>({",
      "\t\tqueryKey: ${3:queryKeys}.${9:method}(${6:params}),",
      "\t\tqueryFn: async () => {",
      "\t\t\tconst response = await client.${10:apiCall}(${6:params})",
      "\t\t\treturn response.${11:data}",
      "\t\t},",
      "\t\tstaleTime: 5 * 60_000,",
      "\t})",
      "}"
    ],
    "description": "React Query v5 useQuery hook (web-next UG client pattern)"
  },
  "React Query useMutation hook": {
    "prefix": "um",
    "body": [
      "import { useMutation, useQueryClient, type UseMutationResult } from '@tanstack/react-query'",
      "import { ${1:useClient} } from '${2:../utils/ug}'",
      "import { ${3:queryKeys} } from './${4:queryKeys}'",
      "",
      "export type ${5:Action}Input = {",
      "\t$0",
      "}",
      "",
      "export const use${5:Action}Mutation = (): UseMutationResult<",
      "\t${6:ResponseType},",
      "\tError,",
      "\t${5:Action}Input",
      "> => {",
      "\tconst client = ${1:useClient}()",
      "\tconst queryClient = useQueryClient()",
      "",
      "\treturn useMutation<${6:ResponseType}, Error, ${5:Action}Input>({",
      "\t\tmutationFn: async (input) => {",
      "\t\t\treturn client.${7:apiCall}(input)",
      "\t\t},",
      "\t\tonSuccess: async (_data, variables) => {",
      "\t\t\tawait queryClient.invalidateQueries({ queryKey: ${3:queryKeys}.${8:method}(variables.${9:id}) })",
      "\t\t},",
      "\t})",
      "}"
    ],
    "description": "React Query v5 useMutation hook with cache invalidation (web-next pattern)"
  },
  "React Query queryKeys factory": {
    "prefix": "qk",
    "body": [
      "export const ${1:domain}QueryKeys = {",
      "\tall: ['${1:domain}'] as const,",
      "",
      "\t${2:list}: () => [...${1:domain}QueryKeys.all, '${2:list}'] as const,",
      "",
      "\t${3:detail}: (${4:id}: string) => [...${1:domain}QueryKeys.${2:list}(), ${4:id}] as const,",
      "} as const"
    ],
    "description": "Hierarchical query-key factory with `as const` (web-next pattern)"
  },
  "React Query invalidateQueries": {
    "prefix": "inv",
    "body": ["await queryClient.invalidateQueries({ queryKey: ${1:queryKeys}.${2:method}(${3:params}) })"],
    "description": "queryClient.invalidateQueries call"
  },

  "Zod object schema": {
    "prefix": "zobj",
    "body": [
      "const ${1:Name}Schema = z.object({",
      "\t${2:field}: z.${3:string}(),",
      "\t$0",
      "})",
      "",
      "type ${1:Name} = z.infer<typeof ${1:Name}Schema>"
    ],
    "description": "Zod object schema with inferred type"
  },
  "Zod enum": {
    "prefix": "zenum",
    "body": ["const ${1:Name}Schema = z.enum(['${2:value1}', '${3:value2}'])"],
    "description": "Zod enum schema"
  },
  "Zod discriminated union": {
    "prefix": "zdisc",
    "body": [
      "const ${1:Name}Schema = z.discriminatedUnion('type', [",
      "\tz.object({ type: z.literal('${2:kind1}') }),",
      "\tz.object({ type: z.literal('${3:kind2}') }),",
      "])"
    ],
    "description": "Zod discriminated union schema"
  },

  "Jest describe block": {
    "prefix": "desc",
    "body": ["describe('${1:subject}', () => {", "\t$0", "})"],
    "description": "Jest describe block"
  },
  "Jest it test": {
    "prefix": "it",
    "body": ["it('${1:should do something}', () => {", "\t$0", "})"],
    "description": "Jest it test case"
  },
  "Jest it async": {
    "prefix": "ita",
    "body": ["it('${1:should do something}', async () => {", "\t$0", "})"],
    "description": "Jest async it test case"
  },
  "Jest expect": {
    "prefix": "exp",
    "body": ["expect(${1:actual}).${2:toBe}(${3:expected})"],
    "description": "Jest expect assertion"
  },
  "Jest beforeEach": {
    "prefix": "bef",
    "body": ["beforeEach(() => {", "\t$0", "})"],
    "description": "Jest beforeEach hook"
  },
  "Jest mock module": {
    "prefix": "mock",
    "body": ["jest.mock('${1:module}', () => ({", "\t$0", "}))"],
    "description": "Jest mock module factory"
  }
}
